rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: surveys
    // Document ID: auto-generated
    // Fields:
    //   - age: string (optional)
    //   - vaccineOpinion: string (optional)
    //   - importance: string (optional)
    //   - updated: string (optional)
    //   - covid: string (optional)
    //   - doses: string (optional)
    //   - last_5_years: string (optional)
    //   - trust: string (optional)
    //   - influence: string (optional)
    //   - skipped: string (optional)
    //   - skipped_reason: string (optional)
    //   - why_not_vax: string (optional)
    //   - campaigns: string (optional)
    //   - created_at: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "meovacinas@gmail.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "admin@meovacinas.com.br"));
    }

    function isValidSurvey(data) {
      return data.keys().hasAll(['created_at']) &&
             (data.get('age', '') is string) &&
             (data.get('vaccineOpinion', '') is string) &&
             (data.get('importance', '') is string) &&
             (data.get('updated', '') is string) &&
             (data.get('covid', '') is string) &&
             (data.get('doses', '') is string) &&
             (data.get('last_5_years', '') is string) &&
             (data.get('trust', '') is string) &&
             (data.get('influence', '') is string) &&
             (data.get('skipped', '') is string) &&
             (data.get('skipped_reason', '') is string) &&
             (data.get('why_not_vax', '') is string) &&
             (data.get('campaigns', '') is string) &&
             data.created_at is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /surveys/{surveyId} {
      // Allow anonymous creation of surveys
      allow create: if isValidSurvey(request.resource.data);
      
      // Only admins can read or delete surveys
      allow read, delete: if isAdmin();
      
      // Updates are not allowed for surveys once submitted
      allow update: if false;
    }

    match /users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Only admins can manage user roles
      allow write: if isAdmin();
    }
  }
}
