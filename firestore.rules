rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: surveys
    // Document ID: auto-generated
    // Fields:
    //   - age: string (required)
    //   - vaccineOpinion: string (required)
    //   - importance: string (required)
    //   - updated: string (required)
    //   - covid: string (required)
    //   - doses: string (required)
    //   - last_5_years: string (required)
    //   - trust: string (required)
    //   - influence: string (required)
    //   - skipped: string (required)
    //   - skipped_reason: string (optional)
    //   - why_not_vax: string (optional)
    //   - campaigns: string (required)
    //   - interest_campaign_2026: string (required)
    //   - created_at: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "meovacinas@gmail.com" && request.auth.token.email_verified == true) ||
          (request.auth.token.email == "admin@meovacinas.com.br" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidSurvey(data) {
      let requiredFields = [
        'age', 'vaccineOpinion', 'importance', 'updated', 'covid', 
        'doses', 'last_5_years', 'trust', 'influence', 'skipped', 
        'campaigns', 'interest_campaign_2026', 'created_at'
      ];
      let optionalFields = ['skipped_reason', 'why_not_vax'];
      let allFields = requiredFields.concat(optionalFields);
      
      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allFields) &&
             data.age is string &&
             data.vaccineOpinion is string &&
             data.importance is string &&
             data.updated is string &&
             data.covid is string &&
             data.doses is string &&
             data.last_5_years is string &&
             data.trust is string &&
             data.influence is string &&
             data.skipped is string &&
             data.campaigns is string &&
             data.interest_campaign_2026 is string &&
             data.created_at is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /surveys/{surveyId} {
      allow create: if isValidSurvey(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
