{
  "entities": {
    "Survey": {
      "title": "Survey Response",
      "description": "A response to the vaccination survey",
      "type": "object",
      "properties": {
        "age": { "type": "string", "description": "Age group of the respondent" },
        "favor": { "type": "string", "description": "Whether the respondent is in favor of vaccines" },
        "importance": { "type": "string", "description": "Opinion on vaccine importance" },
        "updated": { "type": "string", "description": "Whether vaccination status is updated" },
        "covid": { "type": "string", "description": "COVID-19 vaccination status" },
        "doses": { "type": "string", "description": "Number of COVID-19 doses" },
        "last_5_years": { "type": "string", "description": "Number of vaccines in last 5 years" },
        "trust": { "type": "string", "description": "Trust in vaccines" },
        "influence": { "type": "string", "description": "Main influence for vaccination" },
        "skipped": { "type": "string", "description": "Whether any vaccine was skipped" },
        "skipped_reason": { "type": "string", "description": "Reason for skipping" },
        "why_not_vax": { "type": "string", "description": "Reason for not vaccinating" },
        "campaigns": { "type": "string", "description": "Opinion on health campaigns" },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of submission" }
      },
      "required": ["age", "favor", "importance", "updated", "covid", "created_at"]
    }
  },
  "firestore": {
    "surveys": {
      "schema": "Survey",
      "description": "Collection of survey responses"
    }
  }
}
