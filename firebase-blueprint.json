{
  "entities": {
    "Survey": {
      "title": "Survey",
      "description": "A survey response from a user regarding vaccines.",
      "type": "object",
      "properties": {
        "age": {
          "type": "string",
          "description": "Age range of the respondent."
        },
        "vaccineOpinion": {
          "type": "string",
          "description": "General opinion on vaccines."
        },
        "importance": {
          "type": "string",
          "description": "Perceived importance of vaccines."
        },
        "updated": {
          "type": "string",
          "description": "Whether their vax card is updated."
        },
        "covid": {
          "type": "string",
          "description": "COVID vax status."
        },
        "doses": {
          "type": "string",
          "description": "Number of COVID doses."
        },
        "last_5_years": {
          "type": "string",
          "description": "Number of vaccines in last 5 years."
        },
        "trust": {
          "type": "string",
          "description": "Trust level in vaccines."
        },
        "influence": {
          "type": "string",
          "description": "Primary influence source."
        },
        "skipped": {
          "type": "string",
          "description": "Whether they skipped any vax."
        },
        "skipped_reason": {
          "type": "string",
          "description": "Reason for skipping."
        },
        "why_not_vax": {
          "type": "string",
          "description": "Opinion on why people skip."
        },
        "campaigns": {
          "type": "string",
          "description": "Opinion on importance of campaigns."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Submission time."
        }
      },
      "required": [
        "age",
        "vaccineOpinion",
        "importance",
        "updated",
        "covid",
        "doses",
        "last_5_years",
        "trust",
        "influence",
        "skipped",
        "campaigns",
        "created_at"
      ]
    }
  },
  "firestore": {
    "surveys": {
      "schema": "Survey",
      "description": "Collection for storing survey responses."
    }
  }
}
